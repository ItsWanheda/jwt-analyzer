# ─────────────────────────────────────────────────────────────
# jwt-analyzer — environment variable template.
# Copy to `.env` and `source` it before running:
#   cp .env.example .env
#   set -a && source .env && set +a
# ─────────────────────────────────────────────────────────────

# Path to the secrets wordlist used for brute-force.
# JWTANALYZER_WORDLIST_PATH=utils/wordlists/common_secrets.txt

# Brute-force timeout, in seconds.
# JWT_ANALYZER_TIMEOUT=300

# Parallel workers for the brute-force engine.
# JWT_ANALYZER_WORKERS=8

# Log verbosity: DEBUG | INFO | WARNING | ERROR
# JWT_ANALYZER_LOG_LEVEL=INFO

# Toggle the rich terminal UI. Set to "false" in pure-log contexts (CI).
# JWT_ANALYZER_ENABLE_RICH=true

# Optional: HTTP proxy used when contacting JWKS endpoints.
# HTTPS_PROXY=http://127.0.0.1:8080